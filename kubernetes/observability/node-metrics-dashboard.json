{
  "__inputs": [],
  "__requires": [
    { "type": "grafana",    "id": "grafana",     "name": "Grafana",     "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus",  "name": "Prometheus",  "version": "1.0.0"  },
    { "type": "panel",      "id": "timeseries",  "name": "Time series", "version": ""       },
    { "type": "panel",      "id": "stat",        "name": "Stat",        "version": ""       },
    { "type": "panel",      "id": "bargauge",    "name": "Bar gauge",   "version": ""       }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "links": [],
  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["otel", "nodes", "infrastructure"],
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Node Metrics (OTel hostmetrics)",
  "uid": "otel-node-metrics",
  "version": 1,
  "templating": {
    "list": [
      {
        "hide": 0,
        "label": "Datasource",
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "definition": "label_values(system_cpu_time_seconds_total, host_name)",
        "hide": 0,
        "includeAll": true,
        "allValue": ".+",
        "label": "Node",
        "multi": true,
        "name": "node",
        "query": { "query": "label_values(system_cpu_time_seconds_total, host_name)", "refId": "StandardVariableQuery" },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "CPU Usage %",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red",    "value": 90 }
            ]
          },
          "mappings": []
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none", "textMode": "auto" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "100 - (\n  sum by (host_name) (rate(system_cpu_time_seconds_total{state=\"idle\", host_name=~\"$node\"}[5m]))\n  / sum by (host_name) (rate(system_cpu_time_seconds_total{host_name=~\"$node\"}[5m]))\n  * 100\n)",
          "legendFormat": "{{host_name}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Memory Usage %",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red",    "value": 90 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (host_name) (system_memory_usage_bytes{state=\"used\", host_name=~\"$node\"})\n/ sum by (host_name) (system_memory_usage_bytes{host_name=~\"$node\"})\n* 100",
          "legendFormat": "{{host_name}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Root Disk Usage %",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 75 },
              { "color": "red",    "value": 90 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "system_filesystem_usage_bytes{state=\"used\", mountpoint=\"/\", host_name=~\"$node\"}\n/ (\n  system_filesystem_usage_bytes{state=\"used\", mountpoint=\"/\", host_name=~\"$node\"}\n  + system_filesystem_usage_bytes{state=\"free\", mountpoint=\"/\", host_name=~\"$node\"}\n) * 100",
          "legendFormat": "{{host_name}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Load Average (1m)",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 2 },
              { "color": "red",    "value": 8 }
            ]
          }
        }
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background", "graphMode": "none" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "system_cpu_load_average_1m{host_name=~\"$node\"}",
          "legendFormat": "{{host_name}}",
          "instant": true,
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "CPU Usage % by Node",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "100 - (\n  sum by (host_name) (rate(system_cpu_time_seconds_total{state=\"idle\", host_name=~\"$node\"}[5m]))\n  / sum by (host_name) (rate(system_cpu_time_seconds_total{host_name=~\"$node\"}[5m]))\n  * 100\n)",
          "legendFormat": "{{host_name}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Memory Usage by Node",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "system_memory_usage_bytes{state=\"used\", host_name=~\"$node\"}",
          "legendFormat": "{{host_name}} used",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "system_memory_usage_bytes{state=\"cached\", host_name=~\"$node\"}",
          "legendFormat": "{{host_name}} cached",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "system_memory_usage_bytes{state=\"buffered\", host_name=~\"$node\"}",
          "legendFormat": "{{host_name}} buffered",
          "refId": "C"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Network I/O by Node",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [{ "id": "custom.transform", "value": "negative-Y" }]
          }
        ]
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (host_name) (rate(system_network_io_bytes_total{direction=\"receive\", host_name=~\"$node\"}[5m]))",
          "legendFormat": "{{host_name}} rx",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (host_name) (rate(system_network_io_bytes_total{direction=\"transmit\", host_name=~\"$node\"}[5m]))",
          "legendFormat": "{{host_name}} tx",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Load Average by Node",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "system_cpu_load_average_1m{host_name=~\"$node\"}",
          "legendFormat": "{{host_name}} 1m",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "system_cpu_load_average_5m{host_name=~\"$node\"}",
          "legendFormat": "{{host_name}} 5m",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "system_cpu_load_average_15m{host_name=~\"$node\"}",
          "legendFormat": "{{host_name}} 15m",
          "refId": "C"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Disk I/O by Node",
      "gridPos": { "x": 0, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        },
        "overrides": [
          {
            "matcher": { "id": "byFrameRefID", "options": "B" },
            "properties": [{ "id": "custom.transform", "value": "negative-Y" }]
          }
        ]
      },
      "options": { "tooltip": { "mode": "multi", "sort": "desc" }, "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (host_name) (rate(system_disk_io_bytes_total{direction=\"read\", host_name=~\"$node\"}[5m]))",
          "legendFormat": "{{host_name}} read",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (host_name) (rate(system_disk_io_bytes_total{direction=\"write\", host_name=~\"$node\"}[5m]))",
          "legendFormat": "{{host_name}} write",
          "refId": "B"
        }
      ]
    },
    {
      "id": 10,
      "type": "bargauge",
      "title": "Filesystem Usage",
      "gridPos": { "x": 12, "y": 20, "w": 12, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 0.75 },
              { "color": "red",    "value": 0.90 }
            ]
          }
        }
      },
      "options": {
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "displayMode": "gradient",
        "valueMode": "color"
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "system_filesystem_usage_bytes{state=\"used\", host_name=~\"$node\", mountpoint!~\"/var/lib/kubelet.*|/run/.*|/sys/.*|/dev/.*\"}\n/ (\n  system_filesystem_usage_bytes{state=\"used\", host_name=~\"$node\", mountpoint!~\"/var/lib/kubelet.*|/run/.*|/sys/.*|/dev/.*\"}\n  + system_filesystem_usage_bytes{state=\"free\", host_name=~\"$node\", mountpoint!~\"/var/lib/kubelet.*|/run/.*|/sys/.*|/dev/.*\"}\n)",
          "legendFormat": "{{host_name}} {{mountpoint}}",
          "instant": true,
          "refId": "A"
        }
      ]
    }
  ]
}
